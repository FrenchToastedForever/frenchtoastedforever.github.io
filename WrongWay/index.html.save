
<!DOCTYPE html>
<html>
<head>
  <style>
    * { margin: 0; padding: 0; }
    html, body {
      width: 100%;
      height: 100%;
      overflow: hidden;
      cursor: pointer;
    }
    img {
      width: 100%;
      height: 100%;
      display: block;
    }
  </style>
</head>
<body>
  <img id="bg" src="" alt="">
  <script>
    const images = [
      '/boykisser.gif',
      
      '/image3.jpg',
    ];

    let current = -1;

    function randomImage() {
      let next;
      do { next = Math.floor(Math.random() * images.length); } while (next === current);
      current = next;
      document.getElementById('bg').src = images[current];
    }

    randomImage();
    document.body.addEventListener('click', randomImage);
  </script>
</body>
</html>
